# ==============================================================================
# AI FOUNDRY & MULTI-MODEL DISPATCH CREDENTIALS
# ==============================================================================
AZURE_OPENAI_API_KEY="your_azure_openai_api_key_here"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_VERSION="2024-02-01"

ANTHROPIC_API_KEY="your_anthropic_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
QWEN_API_KEY="your_qwen_api_key_here"

# ==============================================================================
# FULL-STACK OBSERVABILITY (LANGFUSE & OPENTELEMETRY)
# ==============================================================================
LANGFUSE_PUBLIC_KEY="pk-lf-your-public-key"
LANGFUSE_SECRET_KEY="sk-lf-your-secret-key"
LANGFUSE_HOST="https://cloud.langfuse.com"

OTEL_SERVICE_NAME="llmops-mcp-evaluator"
OTEL_TRACES_EXPORTER="console" # Options: console, otlp

# ==============================================================================
# MULTI-TENANT VECTOR BENCHMARKING CONNECTIONS
# ==============================================================================
POSTGRES_VECTOR_URI="postgresql://postgres:securepassword@localhost:5432/aerospace_vectors"
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY="your_qdrant_api_key_here"
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_ENVIRONMENT="us-east-1-aws"

# ==============================================================================
# DEEPEVAL CI/CD ASSERTION THRESHOLDS
# ==============================================================================
DEEPEVAL_STRICT_MODE="true"
MIN_GROUNDEDNESS_SCORE="0.95"