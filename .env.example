# ==============================================================================
# Enterprise Judge Gateway Selection
# Options: "gemini" | "openai" | "azure" | "claude"
# ==============================================================================
EVAL_JUDGE_PROVIDER="gemini"

# --- Provider 1: Google Gemini ---
GEMINI_API_KEY="AIzaSy-..."

# --- Provider 2: Public OpenAI ---
OPENAI_API_KEY="sk-proj-..."

# --- Provider 3: Enterprise Azure OpenAI ---
AZURE_OPENAI_API_KEY="your-azure-key"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_VERSION="2024-02-01"
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME="gpt-4o"

# --- Provider 4: Anthropic Claude ---
ANTHROPIC_API_KEY="sk-ant-..."

# ==============================================================================
# Targeted Vector DB & Observability
# ==============================================================================
QDRANT_URL="http://localhost:6333"
OTEL_SERVICE_NAME="llmops-mcp-evaluator"
OTEL_TRACES_EXPORTER="console"
DEEPEVAL_STRICT_MODE="true"
MIN_GROUNDEDNESS_SCORE="0.95"